#! /usr/bin/env zsh
color_scheme=$(gsettings get org.gnome.desktop.interface color-scheme)
ashes=$(grep -o "ashes" ~/.config/foot/foot.ini)
astral=$(grep -o "astral" ~/.config/foot/foot.ini)

# set wallpaper
if [ "${ashes}" = "ashes" ]; then
    awww img ~/Pictures/Wallpapers/toronto.png &
elif [ "${astral}" = "astral" ]; then
    awww img ~/Pictures/Wallpapers/astral-grave-new-message.png &
elif [ "${color_scheme}" = "'prefer-light'" ]; then
    awww img ~/Pictures/Wallpapers/pinkswirls.jpg &
else
    awww img ~/Pictures/Wallpapers/dark-pink-topo.png &
fi

# open and organize TUIs
kitty --single-instance sh -c "~/Downloads/misc/concord/target/release/concord" &
sleep 1.25
kitty --single-instance sh -c "rmpc" &
sleep 0.5
kitty --single-instance sh -c "cd ~/Downloads/misc/starlit && python -m venv .venv && source .venv/bin/activate && starlit && cd; exec zsh" &
sleep 0.5
niri msg action consume-or-expel-window-left && niri msg action set-column-width '-10%' && niri msg action focus-column-left && niri msg action set-column-width '+10%'
