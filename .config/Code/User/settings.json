    "editor.tokenColorCustomizations": {
        "[E Ink 陰陽 Light]": {
            "textMateRules": [
                {
                    "scope": "variable.other",
                    "settings": {
                        "foreground": "#000000"
                    }
                },
                {
                    "scope": "variable.other.property",
                    "settings": {
                        "foreground": "#000000",
                        "fontStyle":  "italic",
                        "fontFamily": "SpaceMono Nerd Font"
                    }
                },
                {
                    "scope": "variable.other.enummember",
                    "settings": {
                        "foreground": "#000000",
                        "fontStyle": "italic",
                        "fontFamily": "SpaceMono Nerd Font"
                    }
                },
                {
                    "scope": "variable.language",
                    "settings": {
                        "foreground": "#c46088",
                        "fontStyle": "italic bold"
                    }
                },
                {
                    "scope": "entity.name.function",
                    "settings": {
                        "foreground": "#89386e",
                        "fontStyle": ""
                    }
                },
                {
                    "scope": "string.quoted.single, string.quoted.double, string.unquoted, string.regexp",
                    "settings": {
                        "foreground": "#444444",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "comment, comment.line, comment.line.number-sign, comment.block, comment.line.double-slash",
                    "settings": {
                        "foreground": "#6a6a6a",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "constant.numeric, constant.other, constant.language",
                    "settings": {
                        "foreground": "#202020"
                    }
                },
                {
                    "scope": "invalid, invalid.deprecated, invalid.illegal",
                    "settings": {
                        "foreground": "#ec4e4e"
                    }
                },
                {
                    "scope": "keyword.control",
                    "settings": {
                        "foreground": "#000000",
                        "fontStyle": "italic bold"
                    }
                }
            ]
        },
        "[E Ink 陰陽 Dark]": {
            "textMateRules": [
                {
                    "scope": "variable.other",
                    "settings": {
                        "foreground": "#ffffff"
                    }
                },
                {
                    "scope": "variable.other.property",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle":  "italic",
                        "fontFamily": "SpaceMono Nerd Font"
                    }
                },
                {
                    "scope": "variable.other.enummember",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "italic",
                        "fontFamily": "SpaceMono Nerd Font"
                    }
                },
                {
                    "scope": "variable.language",
                    "settings": {
                        "foreground": "#d2789c",
                        "fontStyle": "italic bold"
                    }
                },
                {
                    "scope": "entity.name.function",
                    "settings": {
                        "foreground": "#d293be",
                        "fontStyle": ""
                    }
                },
                {
                    "scope": "string.quoted.single, string.quoted.double, string.unquoted, string.regexp",
                    "settings": {
                        "foreground": "#cccccc",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "comment, comment.line, comment.line.number-sign, comment.block, comment.line.double-slash",
                    "settings": {
                        "foreground": "#8a8a8a",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "constant.numeric, constant.other",
                    "settings": {
                        "foreground": "#aaaaaa"
                    }
                },
                {
                    "scope": "invalid, invalid.deprecated, invalid.illegal",
                    "settings": {
                        "foreground": "#ec4e4e"
                    }
                },
                {
                    "scope": "keyword.control",
                    "settings": {
                        "foreground": "#fcdbea",
                        "fontStyle": "italic bold"
                    }
                }
            ]
        }
    },
    "editor.semanticTokenColorCustomizations": {
        "[E Ink 陰陽 Light]": {
            "rules": {
                "function": { "foreground": "#5a1356" }
            }
        },
        "[E Ink 陰陽 Dark]": {
            "rules": {
                "function": { "foreground": "#c093b4" }
            }
        }
    },
